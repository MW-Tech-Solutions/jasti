<IfModule mod_headers.c>
  # Always revalidate the SPA shell so new deployments pick up the latest bundle URLs.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Versioned build assets can be cached aggressively once filenames are hashed.
  Header set Cache-Control "public, max-age=31536000, immutable" "expr=%{REQUEST_URI} =~ m#/(?:[^/]+/)?assets/.+\.[A-Za-z0-9]+$#"
</IfModule>

RewriteEngine On

# Allow API calls
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^ - [L]

# React routing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.html [QSA,L]
